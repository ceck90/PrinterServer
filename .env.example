# Token secret for authentication
TOKEN_KEY=your-secret-key-here

# Base path for reverse proxy support
# If your server is behind a reverse proxy serving on a subpath (e.g., /printers),
# set BASE_PATH to that path WITHOUT trailing slash.
# Leave empty or unset for root path deployment.
# 
# Examples:
# BASE_PATH=/printers
# BASE_PATH=/api/v1/printer-service
# BASE_PATH=
BASE_PATH=
