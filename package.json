{
  "name": "printerserver",
  "description": "Backend per gestione ordini e stampa scontrini su stampanti termiche Ethernet",
  "version": "1.0.0",
  "module": "index.ts",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/stompjs": "^2.3.5",
    "@types/sockjs-client": "^1.5.1"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "elysia": "^1.3.6",
    "escpos-buffer": "^4.1.0",
    "node-thermal-printer": "^4.5.0",
    "sockjs-client": "^1.6.1",
    "stompjs": "^2.3.3"
  },
  "scripts": {
    "dev": "bun src/main.ts",
    "build": "bun build src/main.ts --outdir=dist --target=node",
    "start": "bun run build && bun dist/main.js",
    "test": "bun test",
    "watch": "bun src/main.ts --watch"
  }
}
