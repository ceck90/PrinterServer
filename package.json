{
  "name": "printerserver",
  "description": "Backend per gestione ordini e stampa scontrini su stampanti termiche Ethernet",
  "version": "1.0.0",
  "module": "index.ts",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.15.5",
    "@types/sockjs-client": "^1.5.1",
    "@types/stompjs": "^2.3.5"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3": "^12.2.0",
    "dotenv": "^17.2.2",
    "elysia": "^1.3.6",
    "escpos-buffer": "^4.1.0",
    "escpos-buffer-image": "^1.1.0",
    "html2thermal": "^1.0.7",
    "node-cron": "^4.2.1",
    "node-thermal-printer": "^4.5.0",
    "pg": "^8.16.3",
    "sockjs-client": "^1.6.1",
    "stompjs": "^2.3.3",
    "sweetalert2": "11.22.3"
  },
  "scripts": {
    "dev": "bun src/main.ts",
    "build": "bun build src/main.ts --outdir=dist --target=node",
    "start": "bun run build && bun dist/main.js",
    "test": "bun test",
    "watch": "bun --watch src/main.ts"
